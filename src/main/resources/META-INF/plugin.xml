<idea-plugin>
    <id>com.amfaro.jarify</id>
    <name>Jarify</name>
    <vendor url="https://github.com/amfaro">amfaro</vendor>

    <description><![CDATA[
      Formatting and diagnostics for SQL via the <a href="https://github.com/amfaro/jarify">jarify</a> CLI.
      <ul>
        <li>Reformat Code / format-on-save via <code>jarify fmt</code></li>
        <li>Inline diagnostics via <code>jarify lint --format json</code></li>
        <li>Auto-installs <code>jarify</code> with <code>uv tool install jarify</code> if missing</li>
      </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- JarifySettings is auto-registered via @Service(Level.APP); no <applicationService/> entry needed. -->
        <applicationConfigurable
            parentId="tools"
            instance="com.amfaro.jarify.settings.JarifyConfigurable"
            id="com.amfaro.jarify.settings"
            displayName="Jarify"/>
        <formattingService implementation="com.amfaro.jarify.formatter.JarifyAsyncFormattingService"/>
        <externalAnnotator language="SQL"
                           implementationClass="com.amfaro.jarify.linter.JarifyExternalAnnotator"/>
        <externalAnnotator language="GenericSQL"
                           implementationClass="com.amfaro.jarify.linter.JarifyExternalAnnotator"/>
        <notificationGroup id="Jarify" displayType="BALLOON"/>
        <postStartupActivity implementation="com.amfaro.jarify.install.JarifyInstallStartupActivity"/>
    </extensions>
</idea-plugin>
